# Скопируй в .env и заполни.
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL (или USE_SQLITE=1 для быстрого старта на SQLite)
DB_NAME=autopark
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOW_ALL=True

# --- Хранилище медиа на S3 (Cloudflare R2) ---
# Оставь USE_S3=False для локальной разработки (файлы лягут в backend/media).
# Поставь USE_S3=True и заполни ключи, чтобы фото/логотипы уходили на R2 + CDN.
USE_S3=False
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=autopark-media
# Cloudflare R2 endpoint: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
S3_REGION=auto
# CDN-домен поверх бакета, напр. cdn.твой-домен.kg (без https://)
S3_CUSTOM_DOMAIN=
